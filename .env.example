# Go API
APP_ADDR=:8080
APP_READ_TIMEOUT=10s
APP_WRITE_TIMEOUT=30s
APP_IDLE_TIMEOUT=60s
LOG_BUFFER_SIZE=300

# Upstream ML service for Go API
ML_SERVICE_BASE_URL=http://localhost:8090
ML_SERVICE_TIMEOUT=15s

# Decision engine defaults
DEFAULT_TRUCK_CAPACITY=20
DEFAULT_SAFETY_FACTOR=0.10
MAX_TRUCKS_PER_ROUTE=50
PREDICTION_FLOOR=0
PREDICTION_PRECISION=4
SUBMISSION_DIR=artifacts/submissions

# Python ML stub
ML_SERVICE_HOST=0.0.0.0
ML_SERVICE_PORT=8090
ML_DEFAULT_MODEL=stub_v1
ML_LOG_BUFFER_SIZE=300
